{
  "name": "qinban-ai-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"cd ../backend && uv run uvicorn main:app --host 0.0.0.0 --port 8000 --reload\" \"vite\"",
    "dev:frontend": "vite",
    "dev:backend": "cd ../backend && uv run uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.4.0"
  }
}
