# 亲伴 AI — 环境配置
# 复制此文件为 .env 并填入实际密钥

# ── 后端服务 ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── 数据库 ──
DATABASE_PATH=backend/qinban.db

# ── 语音识别 (STT) ──
# 支持: openai-whisper, azure, baidu
STT_PROVIDER=
STT_API_KEY=
STT_API_URL=
STT_MODEL=whisper-1

# ── 大语言模型 (LLM) ──
# 用于内容改写、安全审查、数字人回复
# 支持: openai, claude, wenxin
LLM_PROVIDER=
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=gpt-4o-mini

# ── 语音合成 (TTS / 数字人) ──
TTS_PROVIDER=
TTS_API_KEY=
TTS_API_URL=

# ── 内容安全 ──
CONTENT_REVIEW_ENABLED=true

# ── OpenAI (Sora 视频生成 / 通用) ──
OPENAI_API_KEY=

# ── DeepSeek AI (视频匹配 / 通用) ──
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Lingya AI (灵崖AI) 视频/文本审查 ──
# 用于检测视频内容是否适合老人观看
# 参考 test_lingya_video.py 中的审查逻辑
LINGYA_API_KEY=
LINGYA_BASE_URL=https://api.lingyaai.cn/v1
LINGYA_MODEL=doubao-seed-2-0-mini
