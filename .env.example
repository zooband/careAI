# 亲伴 AI — 环境配置
# 复制此文件为 .env 并填入实际密钥

# ── 后端服务 ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── 数据库 ──
DATABASE_PATH=backend/qinban.db

# ── 语音识别 (STT) ──
# 支持: openai-whisper, azure, baidu
STT_PROVIDER=
STT_API_KEY=
STT_API_URL=
STT_MODEL=whisper-1

# ── 大语言模型 (LLM) ──
# 用于内容改写、安全审查、数字人回复
# 支持: openai, claude, wenxin
LLM_PROVIDER=
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=gpt-4o-mini

# ── 语音合成 (TTS / 数字人) ──
TTS_PROVIDER=
TTS_API_KEY=
TTS_API_URL=

# ── 内容安全 ──
CONTENT_REVIEW_ENABLED=true
